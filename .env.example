# ── Local development (Supabase CLI) ──
# Run `supabase start` and copy these from the output.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<local-anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<local-service-role-key>

# ── Production (Vercel + Supabase) ──
# Create a Supabase project at https://supabase.com, link it with `supabase link --project-ref <ref>`,
# then run `supabase db push` to apply migrations. Fill in your project's values below.
NEXT_PUBLIC_SUPABASE_URL=https://yciqwmnqpoctrnggemfe.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
